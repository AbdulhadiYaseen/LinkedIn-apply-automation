# Port configuration
PORT=3000

# MongoDB connection URI (Atlas Cloud URI or local instance URI)
# For local: mongodb://127.0.0.1:27017/job-automation
# For cloud: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?appName=<appName>
MONGODB_URI=mongodb://127.0.0.1:27017/job-automation

# OpenRouter Configuration (Required for AI parsing and cover letter composition)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Gmail SMTP Configuration for Nodemailer Outreach
EMAIL=your-gmail-email@gmail.com
APP_PASSWORD=your-gmail-app-password
